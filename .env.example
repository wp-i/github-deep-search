# Prefer using config/user_keys.env for local secrets:
# copy config\user_keys.example.env config\user_keys.env
#
# This .env.example is kept for compatibility with common Python tooling.

# Required for real research. Public repo read-only token is enough.
GITHUB_TOKEN=

# Optional web cross-validation provider.
TAVILY_API_KEY=

# Required for real research: OpenAI-compatible LLM provider.
LLM_API_KEY=
LLM_BASE_URL=https://api.openai.com/v1
LLM_MODEL=your-model-name
LLM_THINKING=
LLM_REASONING_EFFORT=
LLM_INPUT_USD_PER_1M=0
LLM_OUTPUT_USD_PER_1M=0
TAVILY_USD_PER_CREDIT=0.008

# Runtime limits.
MAX_GITHUB_REQUESTS=200
MAX_TAVILY_CREDITS=4
MAX_CANDIDATES=80
MAX_DEEP_ANALYZE_REPOS=3
TASK_DEADLINE_SECONDS=70
